# Provider credentials (uncomment the provider you use)

# AWS Bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Anthropic
# ANTHROPIC_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Atlassian Cloud (Jira + Confluence share the same credentials)
# JIRA_CLOUD_ID=
# JIRA_USER_EMAIL=
# JIRA_API_TOKEN=
# CONFLUENCE_CLOUD_ID=       # falls back to JIRA_CLOUD_ID if not set
# CONFLUENCE_USER_EMAIL=     # falls back to JIRA_USER_EMAIL if not set
# CONFLUENCE_API_TOKEN=      # falls back to JIRA_API_TOKEN if not set

# Apollo.io
# APOLLO_API_KEY=

# Lusha
# LUSHA_API_KEY=

# Datadog
# DD_API_KEY=
# DD_APP_KEY=
# DD_SITE=datadoghq.com

# Slack Channel
# SLACK_APP_TOKEN=xapp-...
# SLACK_BOT_TOKEN=xoxb-...

# API Authentication
# ANDINO_API_KEY=
